.settings-edit-button {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 48rpx;
  width: 48rpx;
  height: 48rpx;
  margin: 0;
  padding: 0;
  background: transparent;
  border: 0;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.settings-edit-button::after {
  border: 0;
}

.settings-edit-button.is-active {
  background: var(--resume-surface-hover, #f9fafb);
}

.edit-icon {
  position: relative;
  width: 28rpx;
  height: 28rpx;
}

.edit-icon-body {
  position: absolute;
  top: 12rpx;
  left: 5rpx;
  width: 22rpx;
  height: 5rpx;
  background: var(--resume-muted, #4b5563);
  border-radius: 4rpx;
  transform: rotate(-45deg);
  transform-origin: center;
}

.edit-icon-tip {
  position: absolute;
  right: 0;
  bottom: 3rpx;
  width: 7rpx;
  height: 7rpx;
  border-right: 3rpx solid var(--resume-muted, #4b5563);
  border-bottom: 3rpx solid var(--resume-muted, #4b5563);
  transform: rotate(45deg);
}
