.settings-edit-button {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 60rpx;
  height: 60rpx;
  margin: 0;
  padding: 0;
  background: var(--resume-surface, #ffffff);
  border: 1rpx solid var(--resume-border, #d1d5db);
  border-radius: 8rpx;
  box-sizing: border-box;
}

.settings-edit-button::after {
  border: 0;
}

.settings-edit-button.is-active {
  border-color: var(--resume-text, #111827);
  box-shadow: inset 0 0 0 1rpx var(--resume-text, #111827);
}

.edit-icon {
  position: relative;
  width: 30rpx;
  height: 30rpx;
}

.edit-icon-body {
  position: absolute;
  top: 13rpx;
  left: 5rpx;
  width: 24rpx;
  height: 6rpx;
  background: var(--resume-text, #111827);
  border-radius: 4rpx;
  transform: rotate(-45deg);
  transform-origin: center;
}

.edit-icon-tip {
  position: absolute;
  right: 0;
  bottom: 3rpx;
  width: 8rpx;
  height: 8rpx;
  border-right: 3rpx solid var(--resume-text, #111827);
  border-bottom: 3rpx solid var(--resume-text, #111827);
  transform: rotate(45deg);
}
