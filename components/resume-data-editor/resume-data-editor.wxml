<view class="resume-data-editor">
  <view class="editor-top">
    <view class="tab-list settings-button-row is-between">
      <button
        wx:for="{{tabs}}"
        wx:key="id"
        class="{{activeTab === item.id ? 'settings-button settings-button-action tab-button is-active' : 'settings-button settings-button-action settings-button-neutral tab-button'}}"
        data-tab="{{item.id}}"
        bindtap="handleTabChange"
      >{{item.label}}</button>
    </view>
    <text class="editor-status">{{editorState.statusText}}</text>
  </view>

  <view wx:if="{{activeTab === 'skills'}}" class="editor-section">
    <view
      wx:for="{{editorState.viewData.skillGroups}}"
      wx:for-item="group"
      wx:for-index="groupIndex"
      wx:key="groupName"
      class="editor-card"
    >
      <view class="card-header">
        <text class="card-title">技能组 {{groupIndex + 1}}</text>
        <button
          wx:if="{{editorState.viewData.skillGroups.length > 1}}"
          class="settings-button settings-button-ghost settings-button-danger text-button danger-button"
          data-section="skillGroup"
          data-group-index="{{groupIndex}}"
          bindtap="handleRemove"
        >删除</button>
      </view>

      <view class="form-field">
        <text class="field-label">分组名称</text>
        <input
          class="text-input"
          value="{{group.groupName}}"
          data-section="skillGroup"
          data-group-index="{{groupIndex}}"
          data-field="groupName"
          maxlength="30"
          bindinput="handleInput"
        />
      </view>

      <view
        wx:for="{{group.skills}}"
        wx:for-item="skill"
        wx:for-index="skillIndex"
        wx:key="name"
        class="nested-card"
      >
        <view class="nested-header">
          <text class="nested-title">技能 {{skillIndex + 1}}</text>
          <button
            wx:if="{{group.skills.length > 1}}"
            class="settings-button settings-button-ghost settings-button-danger text-button danger-button"
            data-section="skill"
            data-group-index="{{groupIndex}}"
            data-skill-index="{{skillIndex}}"
            bindtap="handleRemove"
          >删除</button>
        </view>

        <view class="form-grid">
          <view class="form-field">
            <text class="field-label">名称</text>
            <input
              class="text-input"
              value="{{skill.name}}"
              data-section="skill"
              data-group-index="{{groupIndex}}"
              data-skill-index="{{skillIndex}}"
              data-field="name"
              maxlength="30"
              bindinput="handleInput"
            />
          </view>

          <view class="form-field">
            <text class="field-label">熟练度</text>
            <input
              class="text-input"
              value="{{skill.level}}"
              type="number"
              data-section="skill"
              data-group-index="{{groupIndex}}"
              data-skill-index="{{skillIndex}}"
              data-field="level"
              bindinput="handleInput"
            />
          </view>
        </view>

        <view class="form-field">
          <text class="field-label">标签</text>
          <input
            class="text-input"
            value="{{skill.tagsText}}"
            data-section="skill"
            data-group-index="{{groupIndex}}"
            data-skill-index="{{skillIndex}}"
            data-field="tagsText"
            maxlength="80"
            bindinput="handleInput"
          />
        </view>
      </view>

      <button
        class="settings-button settings-button-inline settings-button-secondary inline-add-button"
        data-section="skill"
        data-group-index="{{groupIndex}}"
        bindtap="handleAdd"
      >新增技能</button>
    </view>

  </view>

  <view wx:if="{{activeTab === 'projects'}}" class="editor-section">
    <view
      wx:for="{{editorState.viewData.projects}}"
      wx:for-item="project"
      wx:for-index="projectIndex"
      wx:key="id"
      class="editor-card"
    >
      <view class="card-header">
        <text class="card-title">项目 {{projectIndex + 1}}</text>
        <button
          wx:if="{{editorState.viewData.projects.length > 1}}"
          class="settings-button settings-button-ghost settings-button-danger text-button danger-button"
          data-section="project"
          data-project-index="{{projectIndex}}"
          bindtap="handleRemove"
        >删除</button>
      </view>

      <view class="form-grid">
        <view class="form-field">
          <text class="field-label">项目名称</text>
          <input
            class="text-input"
            value="{{project.name}}"
            data-section="project"
            data-project-index="{{projectIndex}}"
            data-field="name"
            maxlength="40"
            bindinput="handleInput"
          />
        </view>

        <view class="form-field">
          <text class="field-label">项目 ID</text>
          <input
            class="text-input"
            value="{{project.id}}"
            data-section="project"
            data-project-index="{{projectIndex}}"
            data-field="id"
            maxlength="50"
            bindinput="handleInput"
          />
        </view>
      </view>

      <view class="form-field">
        <text class="field-label">角色</text>
        <input
          class="text-input"
          value="{{project.role}}"
          data-section="project"
          data-project-index="{{projectIndex}}"
          data-field="role"
          maxlength="50"
          bindinput="handleInput"
        />
      </view>

      <view class="form-field">
        <text class="field-label">封面路径</text>
        <input
          class="text-input"
          value="{{project.cover}}"
          data-section="project"
          data-project-index="{{projectIndex}}"
          data-field="cover"
          maxlength="120"
          bindinput="handleInput"
        />
      </view>

      <view class="form-field">
        <text class="field-label">技术栈</text>
        <textarea
          class="textarea-input"
          value="{{project.techStackText}}"
          data-section="project"
          data-project-index="{{projectIndex}}"
          data-field="techStackText"
          maxlength="200"
          auto-height
          bindinput="handleInput"
        ></textarea>
      </view>

      <view class="form-field">
        <text class="field-label">核心亮点</text>
        <textarea
          class="textarea-input"
          value="{{project.highlightsText}}"
          data-section="project"
          data-project-index="{{projectIndex}}"
          data-field="highlightsText"
          maxlength="300"
          auto-height
          bindinput="handleInput"
        ></textarea>
      </view>

      <view
        wx:for="{{project.challenges}}"
        wx:for-item="challenge"
        wx:for-index="challengeIndex"
        wx:key="problem"
        class="nested-card"
      >
        <view class="nested-header">
          <text class="nested-title">难点 {{challengeIndex + 1}}</text>
          <button
            wx:if="{{project.challenges.length > 1}}"
            class="settings-button settings-button-ghost settings-button-danger text-button danger-button"
            data-section="challenge"
            data-project-index="{{projectIndex}}"
            data-challenge-index="{{challengeIndex}}"
            bindtap="handleRemove"
          >删除</button>
        </view>

        <view class="form-field">
          <text class="field-label">问题</text>
          <textarea
            class="textarea-input"
            value="{{challenge.problem}}"
            data-section="challenge"
            data-project-index="{{projectIndex}}"
            data-challenge-index="{{challengeIndex}}"
            data-field="problem"
            maxlength="220"
            auto-height
            bindinput="handleInput"
          ></textarea>
        </view>

        <view class="form-field">
          <text class="field-label">方案</text>
          <textarea
            class="textarea-input"
            value="{{challenge.solution}}"
            data-section="challenge"
            data-project-index="{{projectIndex}}"
            data-challenge-index="{{challengeIndex}}"
            data-field="solution"
            maxlength="260"
            auto-height
            bindinput="handleInput"
          ></textarea>
        </view>

        <view class="form-field">
          <text class="field-label">结果</text>
          <textarea
            class="textarea-input"
            value="{{challenge.result}}"
            data-section="challenge"
            data-project-index="{{projectIndex}}"
            data-challenge-index="{{challengeIndex}}"
            data-field="result"
            maxlength="220"
            auto-height
            bindinput="handleInput"
          ></textarea>
        </view>
      </view>

      <button
        class="settings-button settings-button-inline settings-button-secondary inline-add-button"
        data-section="challenge"
        data-project-index="{{projectIndex}}"
        bindtap="handleAdd"
      >新增难点</button>

      <view class="form-field">
        <text class="field-label">量化成果</text>
        <textarea
          class="textarea-input"
          value="{{project.metricsText}}"
          data-section="project"
          data-project-index="{{projectIndex}}"
          data-field="metricsText"
          maxlength="300"
          auto-height
          bindinput="handleInput"
        ></textarea>
      </view>
    </view>

  </view>

  <view wx:if="{{activeTab === 'timeline'}}" class="editor-section">
    <view
      wx:for="{{editorState.viewData.timeline}}"
      wx:for-item="item"
      wx:for-index="timelineIndex"
      wx:key="title"
      class="editor-card"
    >
      <view class="card-header">
        <text class="card-title">经历 {{timelineIndex + 1}}</text>
        <button
          class="settings-button settings-button-ghost settings-button-danger text-button danger-button"
          data-section="timeline"
          data-timeline-index="{{timelineIndex}}"
          bindtap="handleRemove"
        >删除</button>
      </view>

      <view class="type-list settings-button-row">
        <button
          wx:for="{{timelineTypes}}"
          wx:for-item="type"
          wx:for-index="typeIndex"
          wx:key="id"
          class="{{item.type === type.id ? 'settings-button settings-button-compact type-button is-active' : 'settings-button settings-button-compact type-button'}}"
          data-timeline-index="{{timelineIndex}}"
          data-value="{{type.id}}"
          bindtap="handleTypeTap"
        >{{type.label}}</button>
      </view>

      <view class="form-grid">
        <view class="form-field">
          <text class="field-label">标题</text>
          <input
            class="text-input"
            value="{{item.title}}"
            data-section="timeline"
            data-timeline-index="{{timelineIndex}}"
            data-field="title"
            maxlength="50"
            bindinput="handleInput"
          />
        </view>

        <view class="form-field">
          <text class="field-label">组织</text>
          <input
            class="text-input"
            value="{{item.organization}}"
            data-section="timeline"
            data-timeline-index="{{timelineIndex}}"
            data-field="organization"
            maxlength="50"
            bindinput="handleInput"
          />
        </view>
      </view>

      <view class="form-grid">
        <view class="form-field">
          <text class="field-label">开始</text>
          <input
            class="text-input"
            value="{{item.startDate}}"
            data-section="timeline"
            data-timeline-index="{{timelineIndex}}"
            data-field="startDate"
            maxlength="7"
            bindinput="handleInput"
          />
        </view>

        <view class="form-field">
          <text class="field-label">结束</text>
          <input
            class="text-input"
            value="{{item.endDate}}"
            data-section="timeline"
            data-timeline-index="{{timelineIndex}}"
            data-field="endDate"
            maxlength="7"
            bindinput="handleInput"
          />
        </view>
      </view>

      <view class="form-field">
        <text class="field-label">描述</text>
        <textarea
          class="textarea-input"
          value="{{item.description}}"
          data-section="timeline"
          data-timeline-index="{{timelineIndex}}"
          data-field="description"
          maxlength="220"
          auto-height
          bindinput="handleInput"
        ></textarea>
      </view>
    </view>

  </view>

  <view wx:if="{{activeTab === 'links'}}" class="editor-section">
    <view wx:if="{{!editorState.viewData.contactLinks.length}}" class="empty-card">
      <text class="empty-title">暂无资料项</text>
    </view>

    <view
      wx:for="{{editorState.viewData.contactLinks}}"
      wx:for-item="link"
      wx:for-index="linkIndex"
      wx:key="name"
      class="editor-card"
    >
      <view class="card-header">
        <text class="card-title">资料 {{linkIndex + 1}}</text>
        <button
          class="settings-button settings-button-ghost settings-button-danger text-button danger-button"
          data-section="contactLink"
          data-link-index="{{linkIndex}}"
          bindtap="handleRemove"
        >删除</button>
      </view>

      <view class="type-list settings-button-row">
        <button
          wx:for="{{contactLinkTypes}}"
          wx:for-item="type"
          wx:for-index="typeIndex"
          wx:key="id"
          class="{{link.type === type.id ? 'settings-button settings-button-compact type-button is-active' : 'settings-button settings-button-compact type-button'}}"
          data-link-index="{{linkIndex}}"
          data-value="{{type.id}}"
          bindtap="handleContactLinkTypeTap"
        >{{type.label}}</button>
      </view>

      <view class="form-field">
        <text class="field-label">名称</text>
        <input
          class="text-input"
          value="{{link.name}}"
          data-section="contactLink"
          data-link-index="{{linkIndex}}"
          data-field="name"
          maxlength="30"
          bindinput="handleInput"
        />
      </view>

      <view class="type-list settings-button-row">
        <button
          wx:for="{{contactLinkValueTypes}}"
          wx:for-item="valueType"
          wx:for-index="valueTypeIndex"
          wx:key="id"
          class="{{link.valueType === valueType.id ? 'settings-button settings-button-compact type-button is-active' : 'settings-button settings-button-compact type-button'}}"
          data-link-index="{{linkIndex}}"
          data-value="{{valueType.id}}"
          bindtap="handleContactLinkValueTypeTap"
        >{{valueType.label}}</button>
      </view>

      <view class="form-field">
        <text class="field-label">内容</text>
        <textarea
          class="textarea-input"
          value="{{link.value}}"
          data-section="contactLink"
          data-link-index="{{linkIndex}}"
          data-field="value"
          maxlength="160"
          auto-height
          bindinput="handleInput"
        ></textarea>
      </view>
    </view>

  </view>

  <view class="editor-actions settings-button-row is-between">
    <button
      wx:if="{{activeTab === 'skills'}}"
      class="settings-button settings-button-action settings-button-neutral editor-button action-button"
      data-section="skillGroup"
      bindtap="handleAdd"
    >新增</button>
    <button
      wx:if="{{activeTab === 'projects'}}"
      class="settings-button settings-button-action settings-button-neutral editor-button action-button"
      data-section="project"
      bindtap="handleAdd"
    >新增</button>
    <button
      wx:if="{{activeTab === 'timeline'}}"
      class="settings-button settings-button-action settings-button-neutral editor-button action-button"
      data-section="timeline"
      bindtap="handleAdd"
    >新增</button>
    <button
      wx:if="{{activeTab === 'links'}}"
      class="settings-button settings-button-action settings-button-neutral editor-button action-button"
      data-section="contactLink"
      bindtap="handleAdd"
    >新增</button>
    <button class="settings-button settings-button-action settings-button-primary editor-button primary-button" bindtap="handleSave">保存</button>
    <button class="settings-button settings-button-action settings-button-secondary editor-button secondary-button" bindtap="handleReset">重置</button>
  </view>
</view>
