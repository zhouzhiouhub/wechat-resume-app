@import "../../styles/settings-buttons.wxss";

.resume-data-editor {
  display: grid;
  gap: 18rpx;
}

.editor-top,
.card-header,
.nested-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.editor-top {
  display: grid;
  gap: 12rpx;
  align-items: start;
  justify-content: stretch;
}

.type-button {
  max-width: 124rpx;
}

.editor-status {
  display: block;
  color: var(--resume-subtle, #6b7280);
  font-size: 22rpx;
  line-height: 1.35;
}

.editor-section,
.editor-card,
.nested-card {
  display: grid;
  gap: 16rpx;
}

.editor-card,
.empty-card {
  padding: 18rpx;
  border: 1rpx solid var(--resume-border, #e5e7eb);
  border-radius: 8rpx;
  background: var(--resume-surface, #ffffff);
}

.empty-card {
  justify-items: center;
  color: var(--resume-subtle, #6b7280);
}

.nested-card {
  padding: 16rpx;
  border-radius: 8rpx;
  background: var(--resume-surface-hover, #f9fafb);
}

.card-title,
.nested-title,
.empty-title,
.field-label {
  display: block;
}

.card-title {
  color: var(--resume-text, #111827);
  font-size: 26rpx;
  font-weight: 800;
  line-height: 1.35;
}

.nested-title {
  color: var(--resume-muted, #4b5563);
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.35;
}

.empty-title {
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.35;
}

.text-button {
  max-width: 80rpx;
}

.form-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.form-field {
  min-width: 0;
}

.field-label {
  margin-bottom: 8rpx;
  color: var(--resume-muted, #4b5563);
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.35;
}

.text-input,
.textarea-input {
  width: 100%;
  min-height: 72rpx;
  padding: 0 18rpx;
  border: 1rpx solid var(--resume-border, #e5e7eb);
  border-radius: 8rpx;
  background: var(--resume-surface, #ffffff);
  color: var(--resume-text, #111827);
  font-size: 24rpx;
  line-height: 72rpx;
  box-sizing: border-box;
}

.textarea-input {
  min-height: 120rpx;
  padding-top: 16rpx;
  padding-bottom: 16rpx;
  line-height: 1.5;
}

.inline-add-button {
  justify-self: center;
}

@media (max-width: 420px) {
  .form-grid {
    grid-template-columns: minmax(0, 1fr);
  }

  .editor-top {
    display: grid;
  }
}
