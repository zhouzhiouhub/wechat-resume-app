.tool-panel {
  margin-top: 28rpx;
  padding-bottom: 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.section-heading {
  color: var(--resume-text, #111827);
  font-size: 32rpx;
  font-weight: 700;
}

.tool-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  padding: 24rpx;
  background: var(--resume-surface, #ffffff);
  border: 1rpx solid var(--resume-border, #e5e7eb);
  border-radius: 8rpx;
}

.tool-button {
  min-height: 72rpx;
  padding: 0 12rpx;
  color: var(--resume-accent-text, #3730a3);
  background: var(--resume-accent-soft, #eef2ff);
  border: 1rpx solid var(--resume-border, #e5e7eb);
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 72rpx;
  text-align: center;
  box-sizing: border-box;
}

.tool-button::after {
  border: 0;
}
