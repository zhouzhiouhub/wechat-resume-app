.project-card {
  overflow: hidden;
  margin-top: 16rpx;
  background: var(--resume-surface, #ffffff);
  border: 1rpx solid var(--resume-border, #e5e7eb);
  border-radius: 8rpx;
}

.project-card-hover {
  background: var(--resume-surface-hover, #f9fafb);
}

.project-cover {
  display: block;
  width: 100%;
  height: 248rpx;
  background: var(--resume-track, #e5e7eb);
}

.project-body {
  padding: 24rpx;
}

.project-main {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.project-title-group {
  flex: 1;
  min-width: 0;
}

.project-name {
  display: block;
  color: var(--resume-text, #111827);
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.35;
}

.project-role,
.project-summary {
  display: block;
  color: var(--resume-muted, #4b5563);
  font-size: 26rpx;
  line-height: 1.5;
}

.project-role {
  margin-top: 4rpx;
}

.open-link {
  flex: 0 0 auto;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  background: var(--resume-success-soft, #ecfdf5);
  color: var(--resume-success, #047857);
  font-size: 24rpx;
  line-height: 1.4;
}

.project-summary {
  margin: 14rpx 0 16rpx;
}

.project-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.project-tag {
  padding: 8rpx 14rpx;
  border-radius: 8rpx;
  background: var(--resume-accent-soft, #f3f4f6);
  color: var(--resume-accent-text, #374151);
  font-size: 24rpx;
  line-height: 1.4;
}
