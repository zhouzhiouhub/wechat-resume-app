<view class="resume-preference-settings">
  <view class="preference-block">
    <view class="preference-title-row">
      <text class="preference-title">个人资料</text>
      <text class="preference-meta">本机保存</text>
    </view>

    <view class="form-grid">
      <view class="form-field">
        <text class="field-label">姓名</text>
        <input
          class="text-input"
          value="{{preferenceState.profileDraft.name}}"
          data-field="name"
          maxlength="24"
          bindinput="handleProfileInput"
        />
      </view>

      <view class="form-field">
        <text class="field-label">职位</text>
        <input
          class="text-input"
          value="{{preferenceState.profileDraft.title}}"
          data-field="title"
          maxlength="60"
          bindinput="handleProfileInput"
        />
      </view>

      <view class="form-field">
        <text class="field-label">状态</text>
        <input
          class="text-input"
          value="{{preferenceState.profileDraft.status}}"
          data-field="status"
          maxlength="36"
          bindinput="handleProfileInput"
        />
      </view>

      <view class="form-field">
        <text class="field-label">城市</text>
        <input
          class="text-input"
          value="{{preferenceState.profileDraft.location}}"
          data-field="location"
          maxlength="36"
          bindinput="handleProfileInput"
        />
      </view>

      <view class="form-field form-field-wide">
        <text class="field-label">邮箱</text>
        <input
          class="text-input"
          value="{{preferenceState.profileDraft.email}}"
          data-field="email"
          type="text"
          maxlength="80"
          bindinput="handleProfileInput"
        />
      </view>

      <view class="form-field form-field-wide">
        <text class="field-label">简介</text>
        <textarea
          class="textarea-input"
          value="{{preferenceState.profileDraft.summary}}"
          data-field="summary"
          maxlength="180"
          auto-height
          bindinput="handleProfileInput"
        ></textarea>
      </view>
    </view>
  </view>

  <view class="preference-actions">
    <button class="preference-button primary-button" bindtap="handleSave">保存设置</button>
    <button class="preference-button secondary-button" bindtap="handleReset">恢复默认</button>
  </view>
</view>
