<view class="{{isEditing ? 'resume-preference-settings' : 'resume-preference-settings is-readonly'}}">
  <view class="preference-block">
    <view class="form-grid">
      <view class="form-field">
        <text class="field-label">姓名</text>
        <input
          class="text-input"
          value="{{preferenceState.profileDraft.name}}"
          data-field="name"
          maxlength="24"
          disabled="{{!isEditing}}"
          bindinput="handleProfileInput"
        />
      </view>

      <view class="form-field">
        <text class="field-label">职位</text>
        <input
          class="text-input"
          value="{{preferenceState.profileDraft.title}}"
          data-field="title"
          maxlength="60"
          disabled="{{!isEditing}}"
          bindinput="handleProfileInput"
        />
      </view>

      <view class="form-field">
        <text class="field-label">状态</text>
        <input
          class="text-input"
          value="{{preferenceState.profileDraft.status}}"
          data-field="status"
          maxlength="36"
          disabled="{{!isEditing}}"
          bindinput="handleProfileInput"
        />
      </view>

      <view class="form-field">
        <text class="field-label">城市</text>
        <input
          class="text-input"
          value="{{preferenceState.profileDraft.location}}"
          data-field="location"
          maxlength="36"
          disabled="{{!isEditing}}"
          bindinput="handleProfileInput"
        />
      </view>

      <view class="form-field form-field-wide">
        <text class="field-label">邮箱</text>
        <input
          class="text-input"
          value="{{preferenceState.profileDraft.email}}"
          data-field="email"
          type="text"
          maxlength="80"
          disabled="{{!isEditing}}"
          bindinput="handleProfileInput"
        />
      </view>

      <view class="form-field form-field-wide">
        <text class="field-label">手机号</text>
        <input
          class="text-input"
          value="{{preferenceState.profileDraft.phone}}"
          data-field="phone"
          type="text"
          maxlength="30"
          disabled="{{!isEditing}}"
          bindinput="handleProfileInput"
        />
      </view>

      <view class="form-field form-field-wide">
        <text class="field-label">简介</text>
        <textarea
          class="textarea-input"
          value="{{preferenceState.profileDraft.summary}}"
          data-field="summary"
          maxlength="180"
          auto-height
          disabled="{{!isEditing}}"
          bindinput="handleProfileInput"
        ></textarea>
      </view>
    </view>
  </view>

  <view wx:if="{{isEditing}}" class="preference-actions settings-button-row is-between">
    <button class="settings-button settings-button-action settings-button-primary preference-button primary-button" disabled="{{!isEditing}}" bindtap="handleSave">保存设置</button>
    <button class="settings-button settings-button-action settings-button-secondary preference-button secondary-button" disabled="{{!isEditing}}" bindtap="handleReset">恢复默认</button>
  </view>
</view>
