.resume-preference-settings {
  display: grid;
  gap: 18rpx;
}

.preference-block {
  display: grid;
  gap: 16rpx;
  padding: 18rpx;
  border-radius: 8rpx;
  background: var(--resume-surface-hover, #f9fafb);
}

.preference-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.preference-title,
.preference-meta,
.field-label {
  display: block;
}

.preference-title {
  color: var(--resume-text, #111827);
  font-size: 26rpx;
  font-weight: 800;
  line-height: 1.35;
}

.preference-meta {
  color: var(--resume-subtle, #6b7280);
  font-size: 22rpx;
  line-height: 1.35;
}

.form-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.form-field {
  min-width: 0;
}

.form-field-wide {
  grid-column: 1 / -1;
}

.field-label {
  margin-bottom: 8rpx;
  color: var(--resume-muted, #4b5563);
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.35;
}

.text-input,
.textarea-input {
  width: 100%;
  min-height: 72rpx;
  padding: 0 18rpx;
  border: 1rpx solid var(--resume-border, #e5e7eb);
  border-radius: 8rpx;
  background: var(--resume-surface, #ffffff);
  color: var(--resume-text, #111827);
  font-size: 24rpx;
  line-height: 72rpx;
  box-sizing: border-box;
}

.textarea-input {
  min-height: 132rpx;
  padding-top: 16rpx;
  padding-bottom: 16rpx;
  line-height: 1.5;
}

.preference-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-width: 0;
  margin: 0;
  padding: 0;
  border-radius: 8rpx;
  box-sizing: border-box;
  font-size: 24rpx;
  text-align: center;
  white-space: nowrap;
}

.preference-button::after {
  border: 0;
}

.preference-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  width: 100%;
}

.preference-button {
  height: 68rpx;
  line-height: 1.2;
}

.primary-button {
  background: var(--resume-text, #111827);
  color: var(--resume-inverse, #ffffff);
}

.secondary-button {
  background: var(--resume-accent-soft, #eef2ff);
  color: var(--resume-accent-text, #3730a3);
}

@media (max-width: 420px) {
  .form-grid {
    grid-template-columns: minmax(0, 1fr);
  }
}
