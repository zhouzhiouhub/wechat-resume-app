<view class="{{isEditing ? 'theme-switcher' : 'theme-switcher is-readonly'}}">
  <view
    class="{{isOpen ? 'theme-select is-open' : 'theme-select'}}"
    style="--theme-select-color: {{activeOption.swatchColor}};"
    aria-role="button"
    bindtap="onToggleDropdown"
  >
    <view class="theme-selected">
      <view class="theme-swatch"></view>
      <text class="theme-label">{{activeOption.label}}</text>
    </view>
    <view class="theme-arrow"></view>
  </view>

  <view wx:if="{{isOpen}}" class="theme-options">
    <view
      wx:for="{{options}}"
      wx:key="id"
      class="{{item.isActive ? 'theme-option is-active' : 'theme-option'}}"
      data-theme-id="{{item.id}}"
      style="--theme-option-color: {{item.swatchColor}};"
      aria-role="button"
      catchtap="onSelectTheme"
    >
      <view class="theme-option-main">
        <view class="theme-option-swatch"></view>
        <text class="theme-option-label">{{item.label}}</text>
      </view>
      <view wx:if="{{item.isActive}}" class="theme-option-check"></view>
    </view>
  </view>
</view>
