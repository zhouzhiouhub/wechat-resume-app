.contact-panel {
  margin-top: 28rpx;
  padding-bottom: 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.section-heading {
  color: #111827;
  font-size: 32rpx;
  font-weight: 700;
}

.section-meta {
  color: #4b5563;
  font-size: 24rpx;
}

.contact-card {
  padding: 24rpx;
  background: #ffffff;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
}

.contact-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.contact-label {
  color: #6b7280;
  font-size: 24rpx;
}

.contact-value {
  flex: 1;
  min-width: 0;
  color: #111827;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.4;
  text-align: right;
  word-break: break-all;
}

.contact-actions {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 20rpx;
}

.action-button {
  min-height: 72rpx;
  padding: 0 12rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  line-height: 72rpx;
}

.action-button::after {
  border: 0;
}

.primary-button {
  background: #111827;
  color: #ffffff;
}

.secondary-button {
  background: #ecfdf5;
  color: #047857;
}

.muted-button {
  background: #f3f4f6;
  color: #6b7280;
}

.plain-button {
  background: #eef2ff;
  color: #3730a3;
}
