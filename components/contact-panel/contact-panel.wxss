.contact-panel {
  margin-top: 28rpx;
  padding-bottom: 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.section-heading {
  color: var(--resume-text, #111827);
  font-size: 32rpx;
  font-weight: 700;
}

.contact-card {
  padding: 22rpx 24rpx;
  background: var(--resume-surface, #ffffff);
  border: 1rpx solid var(--resume-border, #e5e7eb);
  border-radius: 8rpx;
}

.contact-rows {
  display: grid;
  gap: 18rpx;
}

.contact-row {
  display: grid;
  grid-template-columns: 88rpx minmax(0, 1fr);
  align-items: center;
  gap: 18rpx;
  min-width: 0;
}

.contact-links {
  display: grid;
  gap: 14rpx;
  margin-top: 22rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--resume-border, #e5e7eb);
}

.contact-links-title {
  color: var(--resume-muted, #4b5563);
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.35;
}

.contact-link {
  padding: 16rpx;
  background: var(--resume-surface-hover, #f9fafb);
  border-radius: 8rpx;
}

.contact-link-main {
  display: grid;
  min-width: 0;
  gap: 4rpx;
}

.contact-link-type,
.contact-link-value {
  color: var(--resume-subtle, #6b7280);
  font-size: 22rpx;
  line-height: 1.35;
}

.contact-link-name {
  color: var(--resume-text, #111827);
  font-size: 26rpx;
  font-weight: 800;
  line-height: 1.35;
}

.contact-link-value {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.contact-label {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  min-height: 42rpx;
  padding: 0 8rpx;
  color: var(--resume-text, #111827);
  background: var(--resume-surface, #ffffff);
  border: 1rpx solid var(--resume-border, #d1d5db);
  border-radius: 4rpx;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 42rpx;
  text-align: center;
  white-space: nowrap;
}

.contact-value {
  box-sizing: border-box;
  min-width: 0;
  color: var(--resume-muted, #374151);
  font-size: 26rpx;
  font-weight: 600;
  line-height: 44rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.contact-value-action {
  min-height: 44rpx;
  padding: 0 4rpx;
  color: var(--resume-text, #111827);
  border-radius: 4rpx;
}

.contact-value text {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
