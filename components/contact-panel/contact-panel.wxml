<view class="contact-panel">
  <view class="section-header">
    <text class="section-heading">联系我</text>
  </view>

  <view class="contact-card">
    <view class="contact-list">
      <view class="contact-info">
        <text class="contact-label">邮箱</text>
        <text class="contact-value">{{contact.email}}</text>
      </view>
      <view wx:if="{{contact.phone}}" class="contact-info">
        <text class="contact-label">手机号</text>
        <text class="contact-value">{{contact.phone}}</text>
      </view>
    </view>

    <view wx:if="{{contact.links.length}}" class="contact-links">
      <text class="contact-links-title">个人资料</text>
      <view
        wx:for="{{contact.links}}"
        wx:for-item="link"
        wx:for-index="linkIndex"
        wx:key="name"
        class="contact-link"
      >
        <view class="contact-link-main">
          <text class="contact-link-type">{{link.typeLabel}}</text>
          <text class="contact-link-name">{{link.name}}</text>
          <text class="contact-link-value">{{link.value}}</text>
        </view>
        <button
          class="link-copy-button"
          data-link-index="{{linkIndex}}"
          bindtap="handleCopyLink"
        >{{link.actionLabel}}</button>
      </view>
    </view>

    <view class="contact-actions">
      <button class="action-button primary-button" bindtap="handleCopyEmail">复制邮箱</button>
      <button
        wx:if="{{contact.phone}}"
        class="action-button secondary-button"
        bindtap="handleCallPhone"
      >拨打电话</button>
      <button
        wx:if="{{contact.wechatQr}}"
        class="action-button secondary-button"
        bindtap="handleShowWechatQr"
      >查看微信二维码</button>
      <button
        wx:else
        class="action-button secondary-button muted-button"
        bindtap="handleShowWechatQr"
      >二维码待补充</button>
    </view>
  </view>
</view>
