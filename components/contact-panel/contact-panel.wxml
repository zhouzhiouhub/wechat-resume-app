<view class="contact-panel">
  <view class="section-header">
    <text class="section-heading">联系我</text>
  </view>

  <view class="contact-card">
    <view class="contact-rows">
      <view class="contact-row">
        <text class="contact-label">邮箱</text>
        <view
          class="contact-value contact-value-action"
          aria-role="button"
          bindtap="handleCopyEmail"
        >
          <text>{{contact.email}}</text>
        </view>
      </view>
      <view wx:if="{{contact.phone}}" class="contact-row">
        <text class="contact-label">手机号</text>
        <view
          class="contact-value contact-value-action"
          aria-role="button"
          bindtap="handleCopyPhone"
        >
          <text>{{contact.phone}}</text>
        </view>
      </view>
      <view class="contact-row">
        <text class="contact-label">微信</text>
        <view
          class="contact-value contact-value-action"
          aria-role="button"
          bindtap="handleShowWechatQr"
        >
          <text>{{contact.wechatQr ? '二维码已配置' : '二维码待补充'}}</text>
        </view>
      </view>
    </view>

    <view wx:if="{{contact.links.length}}" class="contact-links">
      <text class="contact-links-title">个人资料</text>
      <view
        wx:for="{{contact.links}}"
        wx:for-item="link"
        wx:for-index="linkIndex"
        wx:key="name"
        class="contact-link"
      >
        <view
          class="contact-link-main"
          aria-role="button"
          data-link-index="{{linkIndex}}"
          bindtap="handleCopyLink"
        >
          <text class="contact-link-type">{{link.typeLabel}}</text>
          <text class="contact-link-name">{{link.name}}</text>
          <text class="contact-link-value">{{link.value}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
