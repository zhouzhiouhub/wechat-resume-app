.profile-card {
  display: flex;
  gap: 24rpx;
  padding: 32rpx;
  background: #ffffff;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
}

.avatar-image,
.avatar-fallback {
  flex: 0 0 112rpx;
  width: 112rpx;
  height: 112rpx;
  border-radius: 56rpx;
}

.avatar-image {
  display: block;
  background: #e5e7eb;
}

.avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #1f2937;
  color: #ffffff;
  font-size: 40rpx;
  font-weight: 700;
}

.profile-copy {
  flex: 1;
  min-width: 0;
}

.profile-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.profile-name {
  color: #111827;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.2;
}

.status-pill {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #ecfdf5;
  color: #047857;
  font-size: 22rpx;
  line-height: 1.4;
}

.profile-title,
.profile-summary,
.profile-location {
  display: block;
  margin-top: 12rpx;
  color: #4b5563;
  font-size: 28rpx;
  line-height: 1.5;
}

.profile-title {
  color: #111827;
  font-weight: 600;
}
