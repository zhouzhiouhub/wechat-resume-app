<view class="skill-overview">
  <view class="section-header">
    <text class="section-heading">核心技能</text>
  </view>

  <view class="highlight-list">
    <view
      wx:for="{{highlights}}"
      wx:key="name"
      class="highlight-tag"
    >
      <text class="highlight-name">{{item.name}}</text>
      <text class="highlight-description">{{item.description}}</text>
    </view>
  </view>

  <view
    wx:for="{{groups}}"
    wx:key="groupName"
    class="skill-group"
  >
    <view class="skill-group-title">{{item.groupName}}</view>
    <view class="skill-list">
      <view
        wx:for="{{item.skills}}"
        wx:key="name"
        wx:for-item="skill"
        class="skill-row"
      >
        <view class="skill-main">
          <text class="skill-name">{{skill.name}}</text>
          <text class="skill-tags">{{skill.description}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
