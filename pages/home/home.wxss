.home-page {
  min-height: 100vh;
  padding: 32rpx;
}

.section {
  margin-top: 28rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.section-heading {
  color: #111827;
  font-size: 32rpx;
  font-weight: 700;
}

.section-meta {
  color: #4b5563;
  font-size: 24rpx;
}

.error-panel {
  margin-top: 16rpx;
  padding: 24rpx;
  color: #b91c1c;
  background: #fef2f2;
  border: 1rpx solid #fecaca;
  border-radius: 8rpx;
  font-size: 28rpx;
}
