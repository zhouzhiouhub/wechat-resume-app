<view class="home-page">
  <block wx:if="{{loadError}}">
    <view class="error-panel">{{loadError}}</view>
  </block>

  <block wx:elif="{{profile}}">
    <profile-card profile="{{profile}}"></profile-card>

    <skill-overview
      highlights="{{skillHighlights}}"
      groups="{{skillGroups}}"
    ></skill-overview>

    <view class="section">
      <view class="section-header">
        <text class="section-heading">重点项目</text>
        <text class="section-meta">点击查看详情</text>
      </view>
      <project-card
        wx:for="{{featuredProjects}}"
        wx:key="id"
        project="{{item}}"
        bind:open="onOpenProject"
      ></project-card>
    </view>

    <contact-panel
      contact="{{contact}}"
      bind:copyemail="onCopyEmail"
      bind:showwechatqr="onShowWechatQr"
    ></contact-panel>
  </block>
</view>
