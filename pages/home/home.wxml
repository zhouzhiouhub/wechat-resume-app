<view class="home-page {{themeClass}}">
  <block wx:if="{{loadError}}">
    <view class="error-panel">{{loadError}}</view>
  </block>

  <block wx:elif="{{profile}}">
    <view class="resume-shell">
      <view class="resume-topbar">
        <view
          class="menu-toggle"
          aria-role="button"
          bindtap="onToggleMenu"
        >
          <view class="menu-toggle-icon">
            <view></view>
            <view></view>
            <view></view>
          </view>
        </view>

        <view class="content-heading">
          <text class="content-title">{{activeSectionTitle}}</text>
          <text class="content-meta">{{activeSectionMeta}}</text>
        </view>

      </view>

      <view wx:if="{{isMenuVisible}}" class="menu-backdrop" bindtap="onHideMenu"></view>

      <view class="{{isMenuVisible ? 'menu-drawer is-open' : 'menu-drawer'}}">
        <view class="menu-drawer-header">
          <view class="menu-drawer-icon" aria-label="菜单">
            <view></view>
            <view></view>
            <view></view>
          </view>
          <view
            class="menu-close"
            aria-role="button"
            bindtap="onHideMenu"
          >
            <view></view>
            <view></view>
          </view>
        </view>

        <scroll-view
          class="resume-menu"
          scroll-y
          enhanced
          show-scrollbar="{{false}}"
        >
          <view
            wx:for="{{sections}}"
            wx:key="id"
            class="{{item.isActive ? 'menu-item is-active' : 'menu-item'}}"
            aria-role="button"
            data-section-id="{{item.id}}"
            bindtap="onSelectSection"
          >
            <text class="menu-label">{{item.label}}</text>
          </view>
        </scroll-view>
      </view>

      <scroll-view
        class="resume-content"
        scroll-y
        enhanced
        show-scrollbar="{{false}}"
      >
        <view wx:if="{{showProfile}}" class="content-section">
          <profile-card
            profile="{{profile}}"
            bind:avatartap="onAvatarTap"
          ></profile-card>
        </view>

        <view wx:if="{{showSkills}}" class="content-section">
          <skill-overview
            highlights="{{skillHighlights}}"
            groups="{{skillGroups}}"
          ></skill-overview>
        </view>

        <view wx:if="{{showProjects}}" class="content-section section">
          <view class="section-header">
            <text class="section-heading">重点项目</text>
            <text class="section-meta">精选 {{featuredProjectCount}} 项</text>
          </view>
          <project-card
            wx:for="{{featuredProjects}}"
            wx:key="id"
            project="{{item}}"
            bind:open="onOpenProject"
          ></project-card>
        </view>

        <view wx:if="{{showTimeline}}" class="content-section">
          <timeline-view items="{{timelineItems}}"></timeline-view>
        </view>

        <view wx:if="{{showContact}}" class="content-section">
          <contact-panel
            contact="{{contact}}"
            bind:copyemail="onCopyEmail"
            bind:showwechatqr="onShowWechatQr"
            bind:openposter="onOpenPoster"
            bind:openprint="onOpenPrint"
            bind:openfeedback="onOpenFeedback"
          ></contact-panel>
        </view>

        <view wx:if="{{showSettings}}" class="content-section settings-section">
          <view class="settings-panel">
            <view class="section-header">
              <text class="section-heading">素材</text>
              <text class="section-meta">本机保存</text>
            </view>
            <profile-asset-settings
              asset-state="{{profileAssetState}}"
              bind:selectasset="onSelectProfileAsset"
              bind:clearasset="onClearProfileAsset"
            ></profile-asset-settings>
          </view>

          <view class="settings-panel">
            <view class="section-header">
              <text class="section-heading">主题</text>
            </view>
            <theme-switcher
              options="{{themeOptions}}"
              bind:change="onChangeTheme"
            ></theme-switcher>
          </view>
        </view>
      </scroll-view>
    </view>
  </block>
</view>
