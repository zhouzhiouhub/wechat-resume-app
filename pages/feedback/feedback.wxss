.feedback-page {
  min-height: 100vh;
  padding: 32rpx;
  background: var(--resume-bg, #f6f7fb);
  color: var(--resume-text, #111827);
  box-sizing: border-box;
}

.feedback-header {
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid var(--resume-border, #e5e7eb);
}

.feedback-title,
.feedback-subtitle {
  display: block;
}

.feedback-title {
  color: var(--resume-text, #111827);
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1.25;
}

.feedback-subtitle {
  margin-top: 8rpx;
  color: var(--resume-muted, #4b5563);
  font-size: 24rpx;
  line-height: 1.4;
}

.feedback-form {
  margin-top: 24rpx;
  padding: 24rpx;
  background: var(--resume-surface, #ffffff);
  border: 1rpx solid var(--resume-border, #e5e7eb);
  border-radius: 8rpx;
  box-sizing: border-box;
}

.field-group + .field-group {
  margin-top: 24rpx;
}

.field-label {
  display: block;
  margin-bottom: 12rpx;
  color: var(--resume-text, #111827);
  font-size: 26rpx;
  font-weight: 700;
}

.type-options {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
}

.type-option {
  min-height: 68rpx;
  border-radius: 8rpx;
  background: var(--resume-surface-hover, #f9fafb);
  color: var(--resume-muted, #4b5563);
  font-size: 24rpx;
  font-weight: 700;
  line-height: 68rpx;
  text-align: center;
}

.type-option.is-active {
  background: var(--resume-accent-soft, #eef2ff);
  color: var(--resume-accent-text, #3730a3);
  box-shadow: inset 0 0 0 2rpx var(--resume-accent, #2563eb);
}

.text-input,
.text-area {
  width: 100%;
  padding: 0 18rpx;
  border-radius: 8rpx;
  background: var(--resume-surface-hover, #f9fafb);
  color: var(--resume-text, #111827);
  font-size: 26rpx;
  box-sizing: border-box;
}

.text-input {
  height: 76rpx;
  line-height: 76rpx;
}

.text-area {
  min-height: 220rpx;
  padding-top: 18rpx;
  line-height: 1.55;
}

.error-list {
  margin-top: 20rpx;
  padding: 18rpx;
  border-radius: 8rpx;
  background: var(--resume-danger-soft, #fef2f2);
}

.error-text {
  display: block;
  color: var(--resume-danger, #b91c1c);
  font-size: 24rpx;
  line-height: 1.45;
}

.feedback-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 24rpx;
}

.action-button {
  min-height: 76rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  line-height: 76rpx;
}

.action-button::after {
  border: 0;
}

.primary-button {
  background: var(--resume-text, #111827);
  color: var(--resume-inverse, #ffffff);
}

.secondary-button {
  background: var(--resume-accent-soft, #eef2ff);
  color: var(--resume-accent-text, #3730a3);
}

.action-button[disabled] {
  opacity: 0.72;
}
