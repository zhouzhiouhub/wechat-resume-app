.detail-page {
  min-height: 100vh;
  padding: 32rpx;
}

.project-gallery {
  width: 100%;
  height: 390rpx;
  overflow: hidden;
  border-radius: 8rpx;
  background: #e5e7eb;
}

.gallery-image {
  display: block;
  width: 100%;
  height: 390rpx;
}

.detail-section,
.error-panel {
  margin-top: 20rpx;
  padding: 24rpx;
  background: #ffffff;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
}

.project-hero {
  margin-top: 24rpx;
}

.project-name {
  display: block;
  color: #111827;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.25;
}

.project-role,
.project-summary {
  display: block;
  color: #4b5563;
  font-size: 28rpx;
  line-height: 1.5;
}

.project-role {
  margin-top: 8rpx;
  font-weight: 600;
}

.project-summary {
  margin-top: 14rpx;
}

.section-heading {
  display: block;
  margin-bottom: 18rpx;
  color: #111827;
  font-size: 32rpx;
  font-weight: 700;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  padding: 8rpx 14rpx;
  border-radius: 8rpx;
  background: #eef2ff;
  color: #3730a3;
  font-size: 24rpx;
  line-height: 1.4;
}

.list-row,
.metric-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.list-row + .list-row,
.metric-row + .metric-row {
  margin-top: 12rpx;
}

.list-index {
  flex: 0 0 40rpx;
  height: 40rpx;
  border-radius: 20rpx;
  background: #ecfdf5;
  color: #047857;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 40rpx;
  text-align: center;
}

.list-text,
.metric-text,
.challenge-text {
  flex: 1;
  min-width: 0;
  color: #374151;
  font-size: 26rpx;
  line-height: 1.55;
}

.challenge-card {
  padding: 20rpx;
  border-radius: 8rpx;
  background: #f9fafb;
}

.challenge-card + .challenge-card {
  margin-top: 16rpx;
}

.challenge-label {
  display: block;
  margin: 14rpx 0 6rpx;
  color: #111827;
  font-size: 24rpx;
  font-weight: 700;
}

.challenge-label:first-child {
  margin-top: 0;
}

.challenge-text {
  display: block;
}

.metric-dot {
  flex: 0 0 12rpx;
  width: 12rpx;
  height: 12rpx;
  margin-top: 14rpx;
  border-radius: 6rpx;
  background: #2563eb;
}

.back-button {
  margin-top: 24rpx;
  min-height: 76rpx;
  border-radius: 8rpx;
  background: #f3f4f6;
  color: #111827;
  font-size: 28rpx;
  line-height: 76rpx;
}

.back-button::after {
  border: 0;
}

.primary-back {
  background: #111827;
  color: #ffffff;
}

.error-panel {
  color: #b91c1c;
  background: #fef2f2;
  border-color: #fecaca;
  font-size: 28rpx;
}
