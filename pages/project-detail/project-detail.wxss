.detail-page {
  min-height: 100vh;
  padding: 32rpx;
  background: var(--resume-bg, #f6f7fb);
  color: var(--resume-text, #111827);
}

.project-gallery {
  width: 100%;
  height: 390rpx;
  overflow: hidden;
  border-radius: 8rpx;
  background: var(--resume-track, #e5e7eb);
}

.gallery-image {
  display: block;
  width: 100%;
  height: 390rpx;
}

.detail-section,
.error-panel {
  margin-top: 20rpx;
  padding: 24rpx;
  background: var(--resume-surface, #ffffff);
  border: 1rpx solid var(--resume-border, #e5e7eb);
  border-radius: 8rpx;
}

.project-hero {
  margin-top: 24rpx;
}

.project-name {
  display: block;
  color: var(--resume-text, #111827);
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.25;
}

.project-role,
.project-summary {
  display: block;
  color: var(--resume-muted, #4b5563);
  font-size: 28rpx;
  line-height: 1.5;
}

.project-role {
  margin-top: 8rpx;
  font-weight: 600;
}

.project-summary {
  margin-top: 14rpx;
}

.section-heading {
  display: block;
  margin-bottom: 18rpx;
  color: var(--resume-text, #111827);
  font-size: 32rpx;
  font-weight: 700;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  padding: 8rpx 14rpx;
  border-radius: 8rpx;
  background: var(--resume-accent-soft, #eef2ff);
  color: var(--resume-accent-text, #3730a3);
  font-size: 24rpx;
  line-height: 1.4;
}

.list-row,
.metric-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.list-row + .list-row,
.metric-row + .metric-row {
  margin-top: 12rpx;
}

.list-index {
  flex: 0 0 40rpx;
  height: 40rpx;
  border-radius: 20rpx;
  background: var(--resume-success-soft, #ecfdf5);
  color: var(--resume-success, #047857);
  font-size: 22rpx;
  font-weight: 700;
  line-height: 40rpx;
  text-align: center;
}

.list-text,
.metric-text,
.challenge-text {
  flex: 1;
  min-width: 0;
  color: var(--resume-muted, #374151);
  font-size: 26rpx;
  line-height: 1.55;
}

.challenge-card {
  padding: 20rpx;
  border-radius: 8rpx;
  background: var(--resume-surface-hover, #f9fafb);
}

.challenge-card + .challenge-card {
  margin-top: 16rpx;
}

.challenge-label {
  display: block;
  margin: 14rpx 0 6rpx;
  color: var(--resume-text, #111827);
  font-size: 24rpx;
  font-weight: 700;
}

.challenge-label:first-child {
  margin-top: 0;
}

.challenge-text {
  display: block;
}

.metric-dot {
  flex: 0 0 12rpx;
  width: 12rpx;
  height: 12rpx;
  margin-top: 14rpx;
  border-radius: 6rpx;
  background: var(--resume-accent, #2563eb);
}

.back-button {
  margin-top: 24rpx;
  min-height: 76rpx;
  border-radius: 8rpx;
  background: var(--resume-accent-soft, #f3f4f6);
  color: var(--resume-text, #111827);
  font-size: 28rpx;
  line-height: 76rpx;
}

.back-button::after {
  border: 0;
}

.primary-back {
  background: var(--resume-text, #111827);
  color: var(--resume-inverse, #ffffff);
}

.error-panel {
  color: var(--resume-danger, #b91c1c);
  background: var(--resume-danger-soft, #fef2f2);
  border-color: var(--resume-danger-border, #fecaca);
  font-size: 28rpx;
}
