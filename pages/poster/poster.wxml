<view class="poster-page {{themeClass}}">
  <view wx:if="{{loadError}}" class="error-panel">{{loadError}}</view>

  <block wx:elif="{{poster}}">
    <canvas
      wx:if="{{renderPlan}}"
      canvas-id="{{posterCanvasId}}"
      class="poster-canvas"
      style="width: {{renderPlan.canvas.width}}px; height: {{renderPlan.canvas.height}}px;"
    ></canvas>

    <view class="poster-card">
      <view class="poster-header">
        <text class="poster-kicker">{{poster.profile.status}}</text>
        <text class="poster-name">{{poster.profile.name}}</text>
        <text class="poster-title">{{poster.profile.title}}</text>
        <text class="poster-summary">{{poster.profile.summary}}</text>
      </view>

      <view class="poster-section">
        <text class="poster-section-title">核心技能</text>
        <view class="poster-skill-list">
          <view
            wx:for="{{poster.skillTags}}"
            wx:key="name"
            class="poster-skill"
          >
            <text>{{item.name}}</text>
            <text class="poster-skill-description">{{item.description}}</text>
          </view>
        </view>
      </view>

      <view class="poster-section">
        <text class="poster-section-title">代表项目</text>
        <view
          wx:for="{{poster.projects}}"
          wx:key="id"
          class="poster-project"
        >
          <text class="poster-project-name">{{item.name}}</text>
          <text class="poster-project-summary">{{item.summary}}</text>
        </view>
      </view>

      <view class="poster-contact">
        <view>
          <text class="poster-contact-label">联系</text>
          <text class="poster-contact-value">{{poster.contact.email}}</text>
          <text wx:if="{{poster.contact.phone}}" class="poster-contact-label">号码</text>
          <text wx:if="{{poster.contact.phone}}" class="poster-contact-value">{{poster.contact.phone}}</text>
          <block wx:for="{{poster.contact.links}}" wx:key="name">
            <text class="poster-contact-label">{{item.name}}</text>
            <text class="poster-contact-value">{{item.value}}</text>
          </block>
        </view>
        <view class="poster-qr">
          <image
            wx:if="{{poster.contact.wechatQr}}"
            class="poster-qr-image"
            src="{{poster.contact.wechatQr}}"
            mode="aspectFit"
          ></image>
          <text wx:else class="poster-qr-text">二维码待补充</text>
        </view>
      </view>

      <text class="poster-footer">{{poster.footer}}</text>
    </view>

    <view class="poster-actions">
      <button
        class="poster-button primary-button save-button"
        loading="{{isSavingPoster}}"
        disabled="{{isSavingPoster}}"
        bindtap="onSavePoster"
      >{{isSavingPoster ? '生成中' : '保存海报'}}</button>
      <button class="poster-button primary-button" bindtap="onCopyEmail">复制邮箱</button>
      <button class="poster-button secondary-button" bindtap="backHome">返回首页</button>
    </view>
  </block>
</view>
